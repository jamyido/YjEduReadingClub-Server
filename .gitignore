# 环境变量
# .env.development 与 .env.production 为团队共享配置模板，纳入版本控制。
# 个人本地覆盖文件（.env / .env.local / .env.{env}.local）忽略。
.env.development
.env.production

# 编译产物
/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试覆盖率
*.test
*.out
coverage.txt

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 上传文件目录
uploads/

# 依赖目录（Go Modules 本地缓存）
vendor/

# 操作系统文件
.DS_Store
Thumbs.db
