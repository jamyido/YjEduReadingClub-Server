# 数据库连接（MySQL）
# 本地开发示例：mysql://root:password@localhost:3306/yjedu_reading_club
DATABASE_URL="mysql://用户名:密码@主机:端口/数据库名?schema=public"

# JWT 签名密钥（生产环境请使用强随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Token 有效期
JWT_ACCESS_TOKEN_EXPIRES_IN="7d"

# 微信小程序配置（用于微信登录/获取手机号）
WECHAT_MINI_APP_ID=""
WECHAT_MINI_APP_SECRET=""

# 服务端口
PORT=3001
