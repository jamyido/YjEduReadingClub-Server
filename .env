# 开发环境配置
# 启动方式：go run ./cmd/server --env=development（默认即开发环境）

# 数据库连接（PostgreSQL）
# DSN 格式：host=主机 port=端口 user=用户名 password=密码 dbname=数据库名 sslmode=disable TimeZone=Asia/Shanghai
# 开发环境连接远程 PostgreSQL
DATABASE_URL="host= port=5432 user= password= dbname= sslmode=disable TimeZone=Asia/Shanghai"

# JWT 签名密钥（生产环境请使用强随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Token 有效期（支持 d/h/m/s 后缀，如 7d、24h、60m、3600s）
JWT_ACCESS_TOKEN_EXPIRES_IN="7d"

# 微信小程序配置（用于微信登录/获取手机号）
WECHAT_MINI_APP_ID=""
WECHAT_MINI_APP_SECRET=""

# 服务端口
PORT=3100

# 文件上传根目录（相对于服务运行目录）
UPLOAD_DIR="uploads"

# 单文件上传大小上限（MB）
MAX_UPLOAD_SIZE_MB=10

# ===== AI 共读配置 =====
# AI provider 选择：coze / deepseek，留空时按已配置密钥自动探测（DeepSeek 优先）
AI_PROVIDER=deepseek

# DeepSeek 配置（OpenAI 兼容格式）
# 名称：edu
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Coze 配置（备用 provider，可注释掉以彻底禁用）
COZE_TOKEN=
COZE_BOT_ID=
COZE_BASE_URL=https://api.coze.cn